// env.js.template — Plantilla de configuración del frontend
// ─────────────────────────────────────────────────────────────────────────────
// INSTRUCCIONES PARA QUIEN CLONE ESTE REPO:
//
//   1. Copiá este archivo y renombralo a `env.js` en esta misma carpeta.
//   2. Completá los tres valores con tus credenciales reales (ver abajo).
//   3. NUNCA commiteés `env.js` — ya está en .gitignore.
//
// ─────────────────────────────────────────────────────────────────────────────
// DÓNDE CONSEGUIR CADA VALOR:
//
//   SUPABASE_URL      → Supabase Dashboard > Project Settings > API > Project URL
//   SUPABASE_ANON_KEY → Supabase Dashboard > Project Settings > API > anon / public key
//   BACKEND_URL       → URL de tu backend Node.js
//                       · Local:      http://localhost:3000
//                       · Producción: https://tu-backend.railway.app  (o el host que uses)
//
// ─────────────────────────────────────────────────────────────────────────────

window.SUPABASE_URL      = 'REEMPLAZAR_CON_TU_PROJECT_URL';
window.SUPABASE_ANON_KEY = 'REEMPLAZAR_CON_TU_ANON_KEY';
window.BACKEND_URL       = 'http://localhost:3000';

// VAPID_PUBLIC_KEY: solo para web push (no requerido en la app nativa)
// Supabase Dashboard > Settings > Edge Functions > Web Push VAPID o generá con web-push
window.VAPID_PUBLIC_KEY  = '';
