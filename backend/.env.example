# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# service_role key: Supabase Dashboard → Settings → API → service_role
# NUNCA en el frontend ni en repos públicos
SUPABASE_SERVICE_ROLE_KEY=

# ── MercadoPago ───────────────────────────────────────────────────────────────
# Producción: MP Dashboard → Credenciales → Access token (APP_USR-...)
# Sandbox:    MP Dashboard → Credenciales → Access token de prueba (TEST-...)
MP_ACCESS_TOKEN=

# Panel de MP → Tu negocio → Webhooks → Clave secreta de la notificación
MP_WEBHOOK_SECRET=

# ── URLs públicas (sin barra final) ──────────────────────────────────────────
# Desarrollo local:
#   FRONTEND_URL=http://localhost:8000
#   SERVER_URL=http://localhost:3000  (o URL de ngrok si necesitás webhooks)
FRONTEND_URL=https://tudominio.vercel.app
SERVER_URL=https://api.tudominio.com

# ── Puerto ────────────────────────────────────────────────────────────────────
PORT=3000
